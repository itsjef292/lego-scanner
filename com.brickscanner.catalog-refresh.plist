<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Daily offline-catalog refresh (launchd LaunchAgent).

  This is a TEMPLATE: __PROJECT_DIR__ is filled in with the real project path
  by ./install_agents.sh at install time, so it works on any machine/user/path.

  Install (from the project dir):
    ./install_agents.sh          # substitutes paths, copies to ~/Library/LaunchAgents, loads both agents

  Run once now to test:
    launchctl start com.brickscanner.catalog-refresh

  Uninstall:
    launchctl unload ~/Library/LaunchAgents/com.brickscanner.catalog-refresh.plist

  Runs every day at 07:30 local time (America/New_York → Eastern, tracks DST),
  shortly after Rebrickable's ~07:12 ET catalog update. If the Mac is asleep at
  that time, launchd runs it at the next wake. Logs go to catalog_refresh.log.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.brickscanner.catalog-refresh</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/refresh_catalog.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>7</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>

    <!-- The script writes its own timestamped catalog_refresh.log; launchd only
         captures stray stdout/stderr (e.g. uncaught tracebacks) here. -->
    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/catalog_refresh.launchd.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/catalog_refresh.launchd.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
